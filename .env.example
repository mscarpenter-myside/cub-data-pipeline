# ============================================
# CUB Data Pipeline - Environment Variables
# ============================================
# Copy this file to .env and configure as needed:
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to Git!
# ============================================

# ----- Environment -----
# ENV=development
# ENV=production

# ----- Future Integrations (Not Currently Used) -----
# Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ClickUp integration
# CLICKUP_API_KEY=pk_xxxxx

# Database (if needed in future)
# DATABASE_URL=postgresql://user:pass@localhost:5432/cub_data
